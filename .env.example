# ── OpenAI ──────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
OPENAI_MAX_TOKENS=4096
OPENAI_TEMPERATURE=0.2

# ── PostgreSQL ───────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/debugassistant

# ── Redis (optional) ────────────────────────────────────
# REDIS_URL=redis://localhost:6379/0

# ── App ──────────────────────────────────────────────────
DEBUG=false
MAX_LOG_SIZE_MB=10
